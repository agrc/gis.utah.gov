---
/**
 * Utah Design System Header bootstrap.
 *
 * Calls setUtahHeaderSettings() on every page load. The UDS header self-mounts
 * at the top of <body> and renders the Utah footer into the element targeted
 * by `footer.domLocationTarget` (see #utah-footer-placeholder in Chrome.astro).
 */
const currentPath = Astro.url.pathname;
---

<meta name="ugrc-current-path" content={currentPath} />

<script>
  import { setUtahHeaderSettings } from '@utahdts/utah-design-system-header';
  import '@utahdts/utah-design-system-header/css';

  type MenuItem = {
    title: string;
    actionUrl?: { url: string };
    actionMenu?: MenuItem[];
    isSelected?: boolean;
    isDivider?: boolean;
  };

  const meta = document.querySelector('meta[name="ugrc-current-path"]');
  const currentPath = meta?.getAttribute('content') ?? window.location.pathname;
  const fullTitle = 'Utah Geospatial Resource Center';
  const shortTitle = 'UGRC';

  const isActive = (slug: string) => {
    if (slug === '/') {
      return currentPath === '/';
    }
    return currentPath.toLowerCase().startsWith(slug);
  };

  const productsChildren: MenuItem[] = [
    { title: 'SGID', actionUrl: { url: '/products/sgid/' }, isSelected: isActive('/products/sgid/') },
    { title: 'Discover', actionUrl: { url: '/products/discover/' }, isSelected: isActive('/products/discover/') },
    { title: 'TURN GPS', actionUrl: { url: '/products/turn/' }, isSelected: isActive('/products/turn/') },
    { title: 'UGRC API', actionUrl: { url: '/products/api/' }, isSelected: isActive('/products/api/') },
  ];

  const solutionsChildren: MenuItem[] = [
    {
      title: 'Government employees',
      actionUrl: { url: '/solutions/for-government/' },
      isSelected: isActive('/solutions/for-government/'),
    },
    {
      title: 'GIS users',
      actionUrl: { url: '/solutions/for-gis-users/' },
      isSelected: isActive('/solutions/for-gis-users/'),
    },
    {
      title: 'Application developers',
      actionUrl: { url: '/solutions/for-application-developers/' },
      isSelected: isActive('/solutions/for-application-developers/'),
    },
    {
      title: 'Surveyors',
      actionUrl: { url: '/solutions/for-surveyors/' },
      isSelected: isActive('/solutions/for-surveyors/'),
    },
    {
      title: 'Students',
      actionUrl: { url: '/solutions/for-students/' },
      isSelected: isActive('/solutions/for-students/'),
    },
    { title: '--divider--', isDivider: true },
    {
      title: 'Spatial data management',
      actionUrl: { url: '/solutions/spatial-data-management/' },
      isSelected: isActive('/solutions/spatial-data-management/'),
    },
    {
      title: 'Emergency response (911)',
      actionUrl: { url: '/solutions/for-emergency-response/' },
      isSelected: isActive('/solutions/for-emergency-response/'),
    },
    {
      title: 'GIS strategy',
      actionUrl: { url: '/solutions/gis-strategy/' },
      isSelected: isActive('/solutions/gis-strategy/'),
    },
    {
      title: 'Integrating GIS',
      actionUrl: { url: '/solutions/gis-integration/' },
      isSelected: isActive('/solutions/gis-integration/'),
    },
    {
      title: 'High precision location',
      actionUrl: { url: '/solutions/high-precision-location/' },
      isSelected: isActive('/solutions/high-precision-location/'),
    },
  ];

  const menuItems: MenuItem[] = [
    { title: 'Home', actionUrl: { url: '/' }, isSelected: isActive('/') },
    {
      title: 'Products',
      actionUrl: { url: '/products/' },
      actionMenu: productsChildren,
      isSelected: isActive('/products'),
    },
    {
      title: 'Solutions',
      actionUrl: { url: '/solutions/' },
      actionMenu: solutionsChildren,
      isSelected: isActive('/solutions'),
    },
    { title: 'Documentation', actionUrl: { url: '/documentation/' }, isSelected: isActive('/documentation') },
    { title: 'Collaboration', actionUrl: { url: '/collaboration/' }, isSelected: isActive('/collaboration') },
    { title: 'Blog', actionUrl: { url: '/blog/' }, isSelected: isActive('/blog') },
    { title: 'About', actionUrl: { url: '/about/' }, isSelected: isActive('/about') },
    { title: 'Contact', actionUrl: { url: '/contact/' }, isSelected: isActive('/contact') },
  ];

  // Pagefind results rendering inside the UDS search modal.
  type PagefindResultData = {
    url: string;
    excerpt?: string;
    meta?: { title?: string };
  };
  type Pagefind = {
    search: (q: string) => Promise<{
      results: Array<{ data: () => Promise<PagefindResultData> }>;
    }>;
  };

  const MIN_SEARCH_LENGTH = 2;
  const SEARCH_DEBOUNCE_MS = 250;

  let pagefindInstancePromise: Promise<Pagefind> | null = null;
  let activeSearchToken = 0;
  let searchDebounceId: number | null = null;
  const loadPagefind = () => {
    if (!pagefindInstancePromise) {
      // Pagefind bundle is generated at build time and served from /pagefind/pagefind.js.
      // Build the path at runtime so Vite does not try to resolve it during dev/build.
      const pagefindUrl = `${window.location.origin}/pagefind/pagefind.js`;
      pagefindInstancePromise = import(/* @vite-ignore */ pagefindUrl).catch((error) => {
        pagefindInstancePromise = null;
        throw error;
      }) as Promise<Pagefind>;
    }
    return pagefindInstancePromise;
  };

  const getSearchModal = () => document.getElementById('search-modal');

  const getSearchInput = () => document.getElementById('search-modal-input-id') as HTMLInputElement | null;

  const showUdsSearchModal = () => {
    const modal = getSearchModal();
    if (!modal) {
      return;
    }

    modal.classList.remove('visually-hidden');

    const input = getSearchInput();
    const closeButton = modal.querySelector<HTMLButtonElement>('.search-modal__close-button');
    const hiddenLastFocusable = modal.querySelector<HTMLElement>('.search-modal__hidden-last-focusable');

    input?.focus();

    if (closeButton) {
      closeButton.tabIndex = 0;
    }

    if (hiddenLastFocusable) {
      hiddenLastFocusable.tabIndex = 0;
    }
  };

  const ensureResultsContainer = () => {
    const modal = document.querySelector<HTMLElement>('#search-modal .search-modal');
    if (!modal) {
      return null;
    }
    let container = modal.querySelector<HTMLElement>('#ugrc-search-results');
    if (!container) {
      container = document.createElement('div');
      container.id = 'ugrc-search-results';
      container.className = 'ugrc-search-results';
      const form = modal.querySelector('.search-modal__form');
      if (form?.parentElement === modal) {
        form.insertAdjacentElement('afterend', container);
      } else {
        modal.appendChild(container);
      }
    }
    return container;
  };

  const clearSearchResults = () => {
    const container = ensureResultsContainer();
    if (container) {
      container.innerHTML = '';
    }
  };

  const escapeHtml = (value: string) =>
    value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

  const escapeExcerpt = (value: string) => escapeHtml(value).replace(/&lt;(\/?mark)&gt;/g, '<$1>');

  const renderSearchResults = async (phrase: string, options: { reopenModal?: boolean } = {}) => {
    const token = ++activeSearchToken;
    const trimmed = (phrase ?? '').trim();

    if (options.reopenModal) {
      showUdsSearchModal();
    }

    const input = getSearchInput();
    if (input && input.value !== phrase) {
      input.value = phrase;
    }

    const container = ensureResultsContainer();
    if (!container) {
      return;
    }

    if (!trimmed) {
      container.innerHTML = '';
      return;
    }
    if (trimmed.length < MIN_SEARCH_LENGTH) {
      container.innerHTML = `<p class="ugrc-search-results__status" role="status">Type at least ${MIN_SEARCH_LENGTH} characters.</p>`;
      return;
    }

    container.innerHTML = '<p class="ugrc-search-results__status" role="status">Searching…</p>';
    try {
      const pagefind = await loadPagefind();
      if (token !== activeSearchToken) {
        return;
      }

      const result = await pagefind.search(trimmed);
      if (token !== activeSearchToken) {
        return;
      }

      if (!result || !result.results || result.results.length === 0) {
        container.innerHTML = '<p class="ugrc-search-results__status" role="status">No results found.</p>';
        return;
      }

      const topResults = await Promise.all(result.results.slice(0, 10).map((r) => r.data()));
      if (token !== activeSearchToken) {
        return;
      }

      container.innerHTML = `
        <ul class="ugrc-search-results__list" aria-label="Search results">
          ${topResults
            .map((data) => {
              const href = escapeHtml(data.url);
              const title = escapeHtml(data.meta?.title ?? data.url);
              const excerpt = data.excerpt ? escapeExcerpt(data.excerpt) : '';
              return `
                <li class="ugrc-search-results__item">
                  <a class="ugrc-search-results__link" href="${href}">
                    <span class="ugrc-search-results__title">${title}</span>
                    ${excerpt ? `<p class="ugrc-search-results__excerpt">${excerpt}</p>` : ''}
                  </a>
                </li>
              `;
            })
            .join('')}
        </ul>
      `;
    } catch (error) {
      if (token !== activeSearchToken) {
        return;
      }

      console.error('Pagefind search failed', error);
      container.innerHTML = '<p class="ugrc-search-results__status" role="status">Search is unavailable.</p>';
    }
  };

  const bindSearchInput = () => {
    const input = getSearchInput();
    if (!input) {
      return false;
    }
    if (input.dataset.ugrcSearchBound === 'true') {
      return true;
    }

    input.dataset.ugrcSearchBound = 'true';

    input.addEventListener('focus', () => {
      if (!input.value.trim()) {
        activeSearchToken += 1;
        clearSearchResults();
      }
    });

    input.addEventListener('input', () => {
      if (searchDebounceId !== null) {
        window.clearTimeout(searchDebounceId);
        searchDebounceId = null;
      }

      const query = input.value;
      if (!query.trim()) {
        activeSearchToken += 1;
        clearSearchResults();
        return;
      }

      searchDebounceId = window.setTimeout(() => {
        searchDebounceId = null;
        void renderSearchResults(query);
      }, SEARCH_DEBOUNCE_MS);
    });

    return true;
  };

  const bindSearchInputWhenReady = (attempt = 0) => {
    if (bindSearchInput() || attempt >= 30) {
      return;
    }

    window.requestAnimationFrame(() => {
      bindSearchInputWhenReady(attempt + 1);
    });
  };

  setUtahHeaderSettings({
    applicationType: 'static site',
    title: fullTitle,
    titleUrl: '/',
    showTitle: true,
    size: 'MEDIUM',
    skipLinkUrl: '#main-content',
    logo: {
      imageUrl: '/images/ugrc-logo.svg',
    },
    mainMenu: {
      title: `${fullTitle} Main Menu`,
      menuItems,
    },
    utahId: true,
    onSearch: (phrase: string) => {
      // this is required to handle when the user hits "Enter" in the search input, which triggers a form submit instead of an input event. In that case, we want to immediately render results without waiting for the debounce.
      void renderSearchResults(phrase, { reopenModal: true });
    },
    footer: {
      showHorizontalRule: true,
      domLocationTarget: {
        cssSelector: '#utah-footer-placeholder',
      },
    },
  });

  bindSearchInputWhenReady();
</script>

<style is:global>
  /* Keep the legacy submit affordance hidden; search is typeahead-driven. */
  .utah-design-system .search-modal__button-wrapper,
  .utah-design-system .search-modal__button {
    display: none !important;
  }

  /* Pagefind results injected into the UDS search modal */
  .ugrc-search-results {
    position: fixed;
    top: calc(40vh + 4.75rem);
    left: 50%;
    transform: translateX(-50%);
    width: min(720px, calc(100vw - 2rem));
    max-height: calc(60vh - 6rem);
    overflow: auto;
    overscroll-behavior: contain;
    padding: 0 0.25rem 0.25rem;
    z-index: 4010;
  }
  .ugrc-search-results__list {
    list-style: none;
    margin: 0;
    padding: 0 !important;
    display: flex;
    flex-direction: column;
    gap: var(--spacing, 1rem);
  }
  .ugrc-search-results__item {
    margin: 0;
  }
  .ugrc-search-results__item > .ugrc-search-results__link {
    display: block;
    padding: var(--spacing-s, 0.75rem) var(--spacing, 1rem);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.96) !important;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.14);
    color: var(--primary-color, #004f80);
    text-decoration: none;
    transition:
      box-shadow 120ms ease,
      transform 120ms ease,
      border-color 120ms ease;
  }
  .ugrc-search-results__title {
    display: block;
    font-weight: 600;
  }
  .utah-design-system .ugrc-search-results__item > .ugrc-search-results__link:hover,
  .utah-design-system .ugrc-search-results__item > .ugrc-search-results__link:focus {
    text-decoration: none;
    border-color: rgba(0, 79, 128, 0.35);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18) !important;
    transform: translateY(-1px);
  }
  .ugrc-search-results__link:focus-visible {
    outline: 3px solid rgba(0, 79, 128, 0.28);
    outline-offset: 2px;
  }
  .ugrc-search-results__excerpt {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.72);
  }
  .ugrc-search-results__status {
    margin: 0;
    padding: var(--spacing-s, 0.75rem) var(--spacing, 1rem);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 0.5rem;
    background-color: rgba(255, 255, 255, 0.96);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.14);
    font-style: italic;
    color: rgba(0, 0, 0, 0.72);
  }
  .ugrc-search-results mark {
    background-color: var(--accent-color-light, #fff2c0);
    padding: 0 0.15em;
  }

  @media screen and (max-width: 445px) {
    .ugrc-search-results {
      top: calc(40vh + 6.5rem);
      width: calc(100vw - 1rem);
      max-height: calc(60vh - 7rem);
    }

    .utah-design-system .utds-title-wrapper__title {
      font-size: 1.7rem !important;
      line-height: 1 !important;
    }
  }
</style>
